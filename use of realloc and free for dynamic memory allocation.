#include <stdio.h>
#include <stdlib.h>
 
int main() {
int *ptr, i, n1 = 3, n2 = 6;
printf("25331A05D9\n");
ptr = (int*)malloc(n1 * sizeof(int));
for (i = 0; i < n1; i++) ptr[i] = (i + 1) * 10;
printf("Before realloc: ");
for (i = 0; i < n1; i++) printf("%d ", ptr[i]);
ptr = (int*)realloc(ptr, n2 * sizeof(int));
for (i = n1; i < n2; i++) ptr[i] = (i + 1) * 10;
printf("\nAfter realloc:  ");
for (i = 0; i < n2; i++) printf("%d ", ptr[i]);
printf("\n");
free(ptr);
return 0;
}
